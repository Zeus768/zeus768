<?xml version="1.0" encoding="UTF-8"?>
<addons>
    <addon id="plugin.video.orion" name="Orion" version="2.5.0" provider-name="zeus768">
        <requires>
            <import addon="xbmc.python" version="3.0.1"/>
            <import addon="script.module.requests" version="2.25.0"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en">Orion Media Explorer</summary>
            <description lang="en">Orion v2.4.0 - Ultimate streaming addon. Torrent sources: Torrentio, YTS, EZTV, 1337x, PirateBay. Direct streams: VidSrc, HydraHD, FlickyStream, Cineby. Supports Real-Debrid, Premiumize, AllDebrid. TMDB metadata with quality filtering.</description>
            <platform>all</platform>
            <license>GPL-3.0</license>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.jpg</fanart>
            </assets>
        </extension>
    </addon>
    <addon id="repository.zeus768" name="Zeus768 Repository" version="1.0.1" provider-name="zeus768">
        <requires>
            <import addon="xbmc.addon" version="17.9.910"/>
        </requires>
        <extension point="xbmc.addon.repository" name="Zeus768 Repository">
            <dir>
                <info compressed="false">https://raw.githubusercontent.com/Zeus768/zeus768/main/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/Zeus768/zeus768/main/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/Zeus768/zeus768/main/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>Zeus768 Repository</summary>
            <description>Official Zeus768 repository for Kodi addons. Home of Orion Media Explorer.</description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.jpg</fanart>
            </assets>
        </extension>
    </addon>
</addons>
