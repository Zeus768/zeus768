<addons>
    <!-- Main Addons -->
    <addon id="plugin.video.orion" name="Orion" version="3.2.0" provider-name="zeus768">
        <requires>
            <import addon="xbmc.python" version="3.0.1"/>
            <import addon="script.module.requests" version="2.32.5"/>
            <import addon="script.module.resolveurl" version="5.1.193" optional="true"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en">Orion Media Explorer</summary>
            <description lang="en">Orion v3.2.0 - Complete media addon with 15+ torrent scrapers (Torrentio, PirateBay, YTS, EZTV, 1337x, Knaben, TorrentGalaxy, SolidTorrents, BTDig, LimeTorrents, Nyaa, Comet, MediaFusion, Jackettio, Orionoid), Real-Debrid, Premiumize, AllDebrid, Trakt integration, ResolveURL 5.1.193, watch history, favorites, Kids Zone, auto-play next episode.</description>
            <platform>all</platform>
            <license>GPL-3.0</license>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.jpg</fanart>
            </assets>
        </extension>
    </addon>
    <addon id="plugin.program.theaccountant" name="The Accountant" version="3.9.6" provider-name="zeus768">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>executable</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en">The Accountant: Master Pro Suite</summary>
            <description lang="en">v3.9.6: FULL FEATURES - Speed Optimizer, Scheduled Auto-Clean, RD/PM/AD/Trakt/TMDB Auth, IPTV Vault, Favourites Vault, USB Backup, Repair Tools, Cache and Package Cleaner.</description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.jpg</fanart>
            </assets>
        </extension>
    </addon>
    <addon id="plugin.video.strikezone" name="Strike Zone" version="1.2.0" provider-name="zeus768">
