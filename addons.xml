            <import addon="xbmc.python" version="3.0.0"/>
            <import addon="script.module.resolveurl" version="5.1.193"/>
            <import addon="script.module.requests" version="2.32.5"/>
            <import addon="script.module.beautifulsoup4" version="4.14.3"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en">Strike Zone - Watch Fight Replays</summary>
            <description lang="en">Watch UFC, MMA, Boxing, Kickboxing, and more fight replays. Features auto-scrape, infinite scroll, search, favourites, fight metadata and multiple video sources with ResolveURL.</description>
            <platform>all</platform>
            <license>GPL-3.0</license>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.jpg</fanart>
            </assets>
        </extension>
    </addon>
    
