<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
    <category label="Scrapers">
        <setting id="scraper_mode" type="labelenum" label="Scraper Mode" values="Orion Scrapers|Coco Scrapers" default="0"/>
        <setting id="orionoid_enabled" type="bool" label="Enable Orionoid" default="true" visible="eq(-1,0)"/>
        <setting id="torrentio_enabled" type="bool" label="Enable Torrentio" default="true" visible="eq(-2,0)"/>
        <setting id="mediafusion_enabled" type="bool" label="Enable MediaFusion" default="false" visible="eq(-3,0)"/>
        <setting id="jackettio_enabled" type="bool" label="Enable Jackettio" default="false" visible="eq(-4,0)"/>
        <setting id="comet_enabled" type="bool" label="Enable Comet (Stremio)" default="true"/>
        <setting id="coco_piratebay" type="bool" label="Enable PirateBay" default="true" visible="eq(-6,1)"/>
        <setting id="coco_yts" type="bool" label="Enable YTS (Movies)" default="true" visible="eq(-7,1)"/>
        <setting id="coco_eztv" type="bool" label="Enable EZTV (TV Shows)" default="true" visible="eq(-8,1)"/>
        <setting id="coco_1337x" type="bool" label="Enable 1337x" default="true" visible="eq(-9,1)"/>
        <setting id="coco_knaben" type="bool" label="Enable Knaben" default="true" visible="eq(-10,1)"/>
        <setting id="coco_torrentgalaxy" type="bool" label="Enable TorrentGalaxy" default="true" visible="eq(-11,1)"/>
        <setting id="coco_solidtorrents" type="bool" label="Enable SolidTorrents" default="true" visible="eq(-12,1)"/>
        <setting id="coco_limetorrents" type="bool" label="Enable LimeTorrents" default="true" visible="eq(-13,1)"/>
        <setting id="coco_btdig" type="bool" label="Enable BTDig" default="true" visible="eq(-14,1)"/>
        <setting id="coco_nyaa" type="bool" label="Enable Nyaa (Anime)" default="true" visible="eq(-15,1)"/>
        <setting id="coco_torrentdownloads" type="bool" label="Enable TorrentDownloads" default="true" visible="eq(-16,1)"/>
        <setting id="coco_rarbg" type="bool" label="Enable RARBG" default="true" visible="eq(-17,1)"/>
    </category>
    <category label="Orionoid">
        <setting id="orionoid_authorize" type="action" label="Authorize Orionoid" action="RunPlugin(plugin://plugin.video.orion/?action=pair_orionoid)"/>
        <setting id="orionoid_api_key" type="text" label="API Key" default=""/>
        <setting id="orionoid_status" type="text" label="Status" default="Not Authorized" enable="false"/>
    </category>
    <category label="MediaFusion">
        <setting id="mediafusion_configure" type="action" label="Configure MediaFusion" action="RunPlugin(plugin://plugin.video.orion/?action=configure_mediafusion)"/>
        <setting id="mediafusion_manifest" type="text" label="Manifest URL" default=""/>
        <setting id="mediafusion_status" type="text" label="Status" default="Not Configured" enable="false"/>
    </category>
    <category label="Jackettio">
        <setting id="jackettio_configure" type="action" label="Configure Jackettio" action="RunPlugin(plugin://plugin.video.orion/?action=configure_jackettio)"/>
        <setting id="jackettio_manifest" type="text" label="Manifest URL" default=""/>
        <setting id="jackettio_status" type="text" label="Status" default="Not Configured" enable="false"/>
    </category>
    <category label="Real-Debrid">
        <setting id="rd_enabled" type="bool" label="Enable Real-Debrid" default="true"/>
        <setting id="rd_authorize" type="action" label="Authorize Real-Debrid" action="RunPlugin(plugin://plugin.video.orion/?action=pair_rd)"/>
        <setting id="rd_qr_auth" type="action" label="Show QR Code" action="RunPlugin(plugin://plugin.video.orion/?action=qr_rd)"/>
        <setting id="rd_token" type="text" label="Token" default="" visible="false"/>
        <setting id="rd_refresh" type="text" label="Refresh" default="" visible="false"/>
        <setting id="rd_client_id" type="text" label="Client ID" default="" visible="false"/>
        <setting id="rd_client_secret" type="text" label="Secret" default="" visible="false"/>
    </category>
    <category label="Premiumize">
        <setting id="pm_enabled" type="bool" label="Enable Premiumize" default="false"/>
        <setting id="pm_authorize" type="action" label="Authorize Premiumize" action="RunPlugin(plugin://plugin.video.orion/?action=pair_pm)"/>
        <setting id="pm_qr_auth" type="action" label="Show QR Code" action="RunPlugin(plugin://plugin.video.orion/?action=qr_pm)"/>
        <setting id="pm_token" type="text" label="Token" default="" visible="false"/>
    </category>
    <category label="AllDebrid">
        <setting id="ad_enabled" type="bool" label="Enable AllDebrid" default="false"/>
        <setting id="ad_authorize" type="action" label="Authorize AllDebrid" action="RunPlugin(plugin://plugin.video.orion/?action=pair_ad)"/>
        <setting id="ad_qr_auth" type="action" label="Show QR Code" action="RunPlugin(plugin://plugin.video.orion/?action=qr_ad)"/>
        <setting id="ad_token" type="text" label="Token" default="" visible="false"/>
    </category>
    <category label="Trakt">
        <setting id="trakt_enabled" type="bool" label="Enable Trakt" default="false"/>
        <setting id="trakt_authorize" type="action" label="Authorize Trakt" action="RunPlugin(plugin://plugin.video.orion/?action=pair_trakt)"/>
        <setting id="trakt_qr_auth" type="action" label="Show QR Code" action="RunPlugin(plugin://plugin.video.orion/?action=qr_trakt)"/>
        <setting id="trakt_token" type="text" label="Token" default="" visible="false"/>
        <setting id="trakt_refresh" type="text" label="Refresh" default="" visible="false"/>
    </category>
    <category label="Playback">
        <setting id="preferred_quality" type="labelenum" label="Preferred Quality" values="4K|1080p|720p|SD" default="0"/>
        <setting id="auto_play" type="bool" label="Auto-play best quality" default="true"/>
        <setting id="auto_next_episode" type="bool" label="Auto-play next episode" default="true"/>
        <setting id="debrid_priority" type="labelenum" label="Debrid Priority" values="Real-Debrid|Premiumize|AllDebrid" default="0"/>
        <setting id="use_resolveurl" type="bool" label="Use ResolveURL for resolution" default="true"/>
    </category>
    <category label="History &amp; Favorites">
        <setting id="save_history" type="bool" label="Save Watch History" default="true"/>
        <setting id="history_limit" type="slider" label="History Limit" default="100" range="10,10,500"/>
        <setting id="clear_history" type="action" label="Clear Watch History" action="RunPlugin(plugin://plugin.video.orion/?action=clear_history)"/>
        <setting id="clear_favorites" type="action" label="Clear All Favorites" action="RunPlugin(plugin://plugin.video.orion/?action=clear_favorites)"/>
    </category>
    <category label="General">
        <setting id="cache_enabled" type="bool" label="Enable Cache" default="true"/>
        <setting id="cache_hours" type="slider" label="Cache Duration (hours)" default="24" range="1,1,168"/>
        <setting id="clear_cache" type="action" label="Clear Cache" action="RunPlugin(plugin://plugin.video.orion/?action=clear_cache)"/>
    </category>
</settings>
