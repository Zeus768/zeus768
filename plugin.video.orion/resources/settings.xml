<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
    <category label="Orionoid">
        <setting id="orionoid_enabled" type="bool" label="Enable Orionoid" default="true"/>
        <setting id="orionoid_key" type="text" label="Orionoid API Key" default="" option="hidden"/>
        <setting id="orionoid_info" type="lsep" label="Get API key from orionoid.com/panel"/>
    </category>
    <category label="Real-Debrid">
        <setting id="rd_enabled" type="bool" label="Enable Real-Debrid" default="true"/>
        <setting id="rd_authorize" type="action" label="Authorize Real-Debrid" action="RunPlugin(plugin://plugin.video.orion/?action=pair_rd)"/>
        <setting id="rd_qr_auth" type="action" label="Show QR Code" action="RunPlugin(plugin://plugin.video.orion/?action=qr_rd)"/>
        <setting id="rd_token" type="text" label="Token" default="" visible="false"/>
        <setting id="rd_refresh" type="text" label="Refresh" default="" visible="false"/>
        <setting id="rd_client_id" type="text" label="Client ID" default="" visible="false"/>
        <setting id="rd_client_secret" type="text" label="Secret" default="" visible="false"/>
    </category>
    <category label="Premiumize">
        <setting id="pm_enabled" type="bool" label="Enable Premiumize" default="false"/>
        <setting id="pm_authorize" type="action" label="Authorize Premiumize" action="RunPlugin(plugin://plugin.video.orion/?action=pair_pm)"/>
        <setting id="pm_qr_auth" type="action" label="Show QR Code" action="RunPlugin(plugin://plugin.video.orion/?action=qr_pm)"/>
        <setting id="pm_token" type="text" label="Token" default="" visible="false"/>
    </category>
    <category label="AllDebrid">
        <setting id="ad_enabled" type="bool" label="Enable AllDebrid" default="false"/>
        <setting id="ad_authorize" type="action" label="Authorize AllDebrid" action="RunPlugin(plugin://plugin.video.orion/?action=pair_ad)"/>
        <setting id="ad_qr_auth" type="action" label="Show QR Code" action="RunPlugin(plugin://plugin.video.orion/?action=qr_ad)"/>
        <setting id="ad_token" type="text" label="Token" default="" visible="false"/>
    </category>
    <category label="Trakt">
        <setting id="trakt_enabled" type="bool" label="Enable Trakt" default="false"/>
        <setting id="trakt_authorize" type="action" label="Authorize Trakt" action="RunPlugin(plugin://plugin.video.orion/?action=pair_trakt)"/>
        <setting id="trakt_qr_auth" type="action" label="Show QR Code" action="RunPlugin(plugin://plugin.video.orion/?action=qr_trakt)"/>
        <setting id="trakt_token" type="text" label="Token" default="" visible="false"/>
        <setting id="trakt_refresh" type="text" label="Refresh" default="" visible="false"/>
    </category>
    <category label="Playback">
        <setting id="preferred_quality" type="labelenum" label="Preferred Quality" values="4K|1080p|720p|SD" default="0"/>
        <setting id="auto_play" type="bool" label="Auto-play best quality" default="true"/>
        <setting id="debrid_priority" type="labelenum" label="Debrid Priority" values="Real-Debrid|Premiumize|AllDebrid" default="0"/>
    </category>
    <category label="Sources">
        <setting id="sources_sep1" type="lsep" label="--- Stremio Addons ---"/>
        <setting id="enable_torrentio" type="bool" label="Enable Torrentio" default="true"/>
        <setting id="sources_sep2" type="lsep" label="--- Torrent Indexers ---"/>
        <setting id="enable_yts" type="bool" label="Enable YTS (Movies)" default="true"/>
        <setting id="enable_eztv" type="bool" label="Enable EZTV (TV)" default="true"/>
        <setting id="enable_1337x" type="bool" label="Enable 1337x" default="true"/>
        <setting id="enable_piratebay" type="bool" label="Enable PirateBay" default="true"/>
        <setting id="sources_sep3" type="lsep" label="--- Direct Streams ---"/>
        <setting id="enable_vidsrc" type="bool" label="Enable VidSrc" default="true"/>
        <setting id="enable_streaming_sites" type="bool" label="Enable Streaming Sites" default="true"/>
    </category>
    <category label="General">
        <setting id="provider_region" type="labelenum" label="Streaming Provider Region" values="US|GB|CA|AU|DE|FR|ES|IT|JP|KR|BR|MX|IN" default="0"/>
        <setting id="cache_enabled" type="bool" label="Enable Cache" default="true"/>
        <setting id="cache_hours" type="slider" label="Cache Duration (hours)" default="24" range="1,1,168"/>
        <setting id="clear_cache" type="action" label="Clear Cache" action="RunPlugin(plugin://plugin.video.orion/?action=clear_cache)"/>
    </category>
</settings>
